---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PainPointCard from '../components/PainPointCard.astro';
import { siteConfig } from '../data/site-config';

const painPoints = [
  {
    quote: 'Je me sens prisonnier(e) de mes comportements alimentaires',
    description:
      'Les TCA creent un sentiment d\'enfermement. La therapie vous aide a retrouver votre liberte et votre autonomie face a la nourriture.',
  },
  {
    quote: 'La honte m\'empeche d\'en parler',
    description:
      'La honte est l\'un des plus grands obstacles au soin. Dans un espace confidentiel et sans jugement, vous pouvez enfin poser des mots sur votre souffrance.',
  },
  {
    quote: 'J\'ai deja essaye seul(e), sans y parvenir',
    description:
      'Les TCA sont des troubles complexes qui necessitent un accompagnement specialise. Ce n\'est pas un echec de demander de l\'aide.',
  },
  {
    quote: 'Mon rapport a la nourriture affecte toutes mes relations',
    description:
      'Les troubles alimentaires impactent la vie sociale, familiale et professionnelle. Ensemble, nous travaillons a restaurer ces liens.',
  },
  {
    quote: 'La nourriture occupe toutes mes pensees',
    description:
      'L\'obsession alimentaire est epuisante. La therapie vise a apaiser ces pensees pour retrouver de l\'espace mental.',
  },
  {
    quote: 'Je veux m\'en sortir mais je ne sais pas par ou commencer',
    description:
      'Le premier pas est souvent le plus difficile. Un premier echange, sans engagement, peut tout changer.',
  },
];
---

<BaseLayout
  title="Psychologue TCA Lyon - Troubles du Comportement Alimentaire"
  description={siteConfig.description}
  schemaType="homepage"
>
  <Hero />

  <!-- Pain Points Section -->
  <section data-section="pain-points" class="py-16 sm:py-24 bg-offwhite">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-warm-700 mb-4">
          Vous vous reconnaissez ?
        </h2>
        <p class="text-warm-500 text-lg max-w-2xl mx-auto">
          Ces paroles reviennent souvent en consultation. Si l'une d'elles vous parle,
          sachez que vous n'etes pas seul(e) et qu'un accompagnement est possible.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {painPoints.map((point, index) => (
          <PainPointCard
            quote={point.quote}
            description={point.description}
            index={index}
          />
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/contact"
          data-track="cta-premier-pas"
          class="inline-flex items-center px-8 py-4 bg-peach-500 text-white font-semibold rounded-full hover:bg-peach-600 transition-all hover:shadow-lg hover:shadow-peach-500/25"
        >
          Faire le premier pas
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Approach Preview Section -->
  <section data-section="approach" class="py-16 sm:py-24 bg-cream-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-3xl sm:text-4xl font-bold text-warm-700 mb-6">
            Une approche douce et specialisee
          </h2>
          <p class="text-warm-500 text-lg mb-6 leading-relaxed">
            Je suis {siteConfig.therapist.name}, {siteConfig.therapist.title.toLowerCase()},
            specialisee dans l'accompagnement des troubles du comportement alimentaire depuis plus de 10 ans.
          </p>
          <p class="text-warm-500 mb-8 leading-relaxed">
            Mon approche integre la Therapie Cognitivo-Comportementale (TCC) et des techniques de pleine conscience,
            adaptees a chaque parcours individuel. L'objectif n'est pas de controler, mais de comprendre et d'apaiser.
          </p>
          <ul class="space-y-3 mb-8">
            {siteConfig.therapist.specialties.slice(0, 4).map((specialty) => (
              <li class="flex items-center gap-3 text-warm-600">
                <svg class="w-5 h-5 text-sage-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {specialty}
              </li>
            ))}
          </ul>
          <a
            href="/about"
            class="inline-flex items-center text-peach-500 font-semibold hover:text-peach-600 transition-colors"
          >
            En savoir plus sur mon approche
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <div class="bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-cream-200">
          <div class="text-center">
            <div class="w-24 h-24 bg-gradient-to-br from-peach-100 to-sky-100 rounded-full mx-auto mb-6 flex items-center justify-center">
              <span class="text-3xl" aria-hidden="true">&#128330;</span>
            </div>
            <h3 class="font-heading text-2xl font-semibold text-warm-700 mb-2">
              {siteConfig.therapist.name}
            </h3>
            <p class="text-warm-400 mb-6">{siteConfig.therapist.title}</p>
            <div class="space-y-3 text-sm text-warm-500">
              <p class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {siteConfig.address.street}, {siteConfig.address.postalCode} {siteConfig.address.city}
              </p>
              <p class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {siteConfig.openingHours.days}, {siteConfig.openingHours.hours}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Preview Section -->
  <section data-section="blog-preview" class="py-16 sm:py-24 bg-offwhite">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-warm-700 mb-4">
        Comprendre les TCA
      </h2>
      <p class="text-warm-500 text-lg max-w-2xl mx-auto mb-10">
        Des ressources pour mieux comprendre les troubles du comportement alimentaire et les chemins vers la guerison.
      </p>
      <a
        href="/blog"
        class="inline-flex items-center px-8 py-4 bg-white text-warm-600 font-semibold rounded-full border border-cream-300 hover:border-peach-300 hover:text-peach-600 transition-all"
      >
        Voir toutes les ressources
      </a>
    </div>
  </section>

  <!-- CTA Section -->
  <section data-section="cta" class="py-16 sm:py-24 bg-gradient-to-r from-peach-500 to-peach-600">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-white mb-6">
        Le premier pas est le plus courageux
      </h2>
      <p class="text-peach-100 text-lg mb-10 max-w-2xl mx-auto">
        Vous n'avez pas besoin d'etre pret(e) pour commencer. Juste d'avoir envie que les choses changent.
        Contactez-moi pour un premier echange, sans engagement.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          data-track="cta-rdv"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 bg-white text-peach-600 font-semibold rounded-full hover:bg-peach-50 transition-all"
        >
          Prendre rendez-vous
        </a>
        <a
          href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-full hover:bg-white/10 transition-all"
        >
          {siteConfig.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
