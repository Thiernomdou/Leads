---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (!accessToken) {
  return Astro.redirect('/admin/login');
}
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Admin</title>
  </head>
  <body class="min-h-screen bg-warm-50">
    <!-- Admin Header -->
    <header class="bg-warm-700 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">
        <div class="flex items-center gap-4">
          <a href="/admin" class="font-semibold text-sm">Admin Dashboard</a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/" class="text-warm-300 hover:text-white text-sm transition-colors">
            Voir le site
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-warm-300 hover:text-white text-sm transition-colors">
              Deconnexion
            </button>
          </form>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>
  </body>
</html>
