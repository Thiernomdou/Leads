---
import { siteConfig } from '../data/site-config';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/about', label: 'Approche' },
  { href: '/blog', label: 'Ressources' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-offwhite/95 backdrop-blur-sm border-b border-cream-200">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16 sm:h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-peach-500 text-2xl" aria-hidden="true">&#9752;</span>
      <span class="font-heading text-lg sm:text-xl font-semibold text-warm-700 group-hover:text-peach-600 transition-colors">
        {siteConfig.shortName}
      </span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-peach-500',
              currentPath === link.href ? 'text-peach-500' : 'text-warm-500',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 bg-peach-500 text-white text-sm font-medium rounded-full hover:bg-peach-600 transition-colors"
        >
          Prendre rendez-vous
        </a>
      </li>
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-warm-500 hover:text-warm-700"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-cream-200 bg-offwhite">
    <ul class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-2 text-base font-medium transition-colors',
              currentPath === link.href ? 'text-peach-500' : 'text-warm-500 hover:text-peach-500',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/contact"
          class="block text-center px-5 py-3 bg-peach-500 text-white font-medium rounded-full hover:bg-peach-600 transition-colors"
        >
          Prendre rendez-vous
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
