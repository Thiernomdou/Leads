---
import { siteConfig } from '../data/site-config';
---

<section class="relative overflow-hidden bg-gradient-to-br from-offwhite via-cream-50 to-sky-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 lg:py-32">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-peach-50 border border-peach-200 rounded-full mb-8">
        <span class="w-2 h-2 bg-sage-500 rounded-full"></span>
        <span class="text-sm font-medium text-warm-600">Specialiste TCA a Lyon</span>
      </div>

      <!-- Heading -->
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-warm-700 mb-6 leading-tight">
        Retrouvez une relation
        <span class="text-peach-500">apaisee</span>
        avec la nourriture
      </h1>

      <!-- Subheading -->
      <p class="text-lg sm:text-xl text-warm-500 mb-10 max-w-2xl mx-auto leading-relaxed">
        Accompagnement psychologique specialise dans les troubles du comportement alimentaire.
        Un espace bienveillant pour comprendre, apaiser et guerir.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 bg-peach-500 text-white font-semibold rounded-full hover:bg-peach-600 transition-all hover:shadow-lg hover:shadow-peach-500/25"
        >
          Prendre rendez-vous
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/blog"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 bg-white text-warm-600 font-semibold rounded-full border border-cream-300 hover:border-peach-300 hover:text-peach-600 transition-all"
        >
          Comprendre les TCA
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-6 text-sm text-warm-400">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Psychologue diplomee</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Premier rendez-vous sous 48h</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-sage-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>Lyon 2e - Bellecour</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-peach-100/30 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-sky-100/30 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
</section>
