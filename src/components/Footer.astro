---
import { siteConfig } from '../data/site-config';

const currentYear = new Date().getFullYear();
---

<footer class="bg-warm-700 text-warm-100 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <span class="text-peach-400 text-2xl" aria-hidden="true">&#9752;</span>
          <span class="font-heading text-lg font-semibold text-white">
            {siteConfig.shortName}
          </span>
        </a>
        <p class="text-warm-300 text-sm leading-relaxed">
          {siteConfig.description}
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-white text-lg mb-4">Contact</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-warm-200 hover:text-peach-400 transition-colors">
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="text-warm-200 hover:text-peach-400 transition-colors">
              {siteConfig.email}
            </a>
          </li>
          <li class="text-warm-300">
            {siteConfig.address.street}<br />
            {siteConfig.address.postalCode} {siteConfig.address.city}
          </li>
          <li class="text-warm-300">
            {siteConfig.openingHours.days}<br />
            {siteConfig.openingHours.hours}
          </li>
        </ul>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-heading text-white text-lg mb-4">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-warm-200 hover:text-peach-400 transition-colors">Accueil</a></li>
          <li><a href="/about" class="text-warm-200 hover:text-peach-400 transition-colors">Mon approche</a></li>
          <li><a href="/blog" class="text-warm-200 hover:text-peach-400 transition-colors">Ressources</a></li>
          <li><a href="/contact" class="text-warm-200 hover:text-peach-400 transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-heading text-white text-lg mb-4">Informations</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/mentions-legales" class="text-warm-200 hover:text-peach-400 transition-colors">Mentions legales</a></li>
          <li class="text-warm-300">{siteConfig.therapist.credentials}</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-warm-600 mt-10 pt-8 text-center text-sm text-warm-400">
      <p>&copy; {currentYear} {siteConfig.name}. Tous droits reserves.</p>
    </div>
  </div>
</footer>
